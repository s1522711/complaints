# ─────────────────────────────────────────
# Server
# ─────────────────────────────────────────
PORT=3000
# Public-facing base URL used in emails (no trailing slash). Optional but recommended.
# Example: https://germani.dev/complaints
SITE_URL=

# ─────────────────────────────────────────
# SMTP Configuration (Custom)
# ─────────────────────────────────────────
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false        # Set to true for port 465 (SSL)
SMTP_USER=you@yourdomain.com
SMTP_PASS=your_smtp_password

# The email address complaints are forwarded TO (your inbox)
ADMIN_EMAIL=you@yourdomain.com

# ─────────────────────────────────────────
# Admin Panel Credentials
# ─────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_a_strong_password

# ─────────────────────────────────────────
# Session Secret (generate a random string)
# ─────────────────────────────────────────
SESSION_SECRET=replace_with_a_long_random_secret_string

# ─────────────────────────────────────────
# Reverse Proxy
# TRUST_PROXY: set to "1" if behind Nginx, Caddy, etc.
# BASE_PATH: sub-path the app is mounted at (e.g. /complaints). Leave blank if at root.
# ─────────────────────────────────────────
TRUST_PROXY=
BASE_PATH=

# ─────────────────────────────────────────
# Cloudflare Turnstile (CAPTCHA)
# Get keys at: https://dash.cloudflare.com/?to=/:account/turnstile
# Leave blank to disable CAPTCHA (e.g. local development)
# ─────────────────────────────────────────
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
